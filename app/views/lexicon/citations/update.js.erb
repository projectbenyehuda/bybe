if ($('#citations').length) {
  // Entry-edit view: lazy-reload just the citations section
  reloadContent($('#citations'));
  <% if @link_check_performed %>
  showToast(<%= @link_toast_message.to_json %>, '<%= @link_toast_type %>');
  <% end %>
} else {
  // Verification view: reload is driven by the openModal onSuccess callback;
  // toast data is already stored in sessionStorage via X-Link-Check-Toast header.
  // This setTimeout is a safety fallback if JS eval runs in a context without an onSuccess.
  setTimeout(function() { location.reload(); }, 300);
}
