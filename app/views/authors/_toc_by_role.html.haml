:ruby
  top_level_by_role = top_nodes.select { |node| node.visible?(role, authority_id) }

  uncollected_node = top_level_by_role.detect { |node| node.collection.uncollected? }
  top_level_by_role -= [uncollected_node] if uncollected_node.present?

  top_level_by_role = top_level_by_role.sort_by do |node|
    if node.collection.normalized_pub_year.present?
      node.collection.normalized_pub_year
    else
      node.collection.created_at.year
    end
  end

- if top_level_by_role.present?
  %div{id: 'works-'+role.to_s, role: 'tabpanel'}
    .headline-books= title
    %ul.toclist{role: 'tree'}
      = render partial: 'authors/toc_node', collection: top_level_by_role, locals: { role: role, authority_id: authority_id, editable: editable, nonce: nonce, uncollected: false, full_toc: false }

- if uncollected_node.present?
  %div{id: 'works-'+role.to_s+'-uncollected', role: 'tabpanel'}
    .headline-books= "#{title} (#{t(:uncollected_works)})"
    %ul.toclist{role: 'tree'}
    = render partial: 'authors/toc_node', collection: uncollected_node.children, locals: { role: role, authority_id: authority_id, editable: editable, nonce: "#{nonce}-uncollected", uncollected: false, full_toc: false }