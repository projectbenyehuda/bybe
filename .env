BY_LANGUAGE=he # locale used for UI
ELASTICSEARCH_HOST=127.0.0.1:19200
REDIS_URL=redis://127.0.0.1:16379

# NOTE: by default Rails disables caching in development or test environments.
# You can toggle it by running command `rails dev:cache` or `rails test:cache`
MEMCACHE_SERVERS=127.0.0.1:21211

APP_HOSTNAME=benyehuda.org

S3_BUCKET=bybeprod
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=sample-access-key-id
AWS_SECRET_ACCESS_KEY=sample-secret-access-key
GOOGLE_API_KEY=google_api_key
TASK_SYSTEM_HOST=localhost
TASK_SYSTEM_PORT=3001
GOOGLE_OAUTH_CLIENT_ID=google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=google_oauth_client_secret

# To be removed ater we remove HtmlFiles completely
BASE_DIR=/var/www/my_actual_static_files_dir
